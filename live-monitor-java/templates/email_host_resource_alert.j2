<div style="font-family:Arial,'Microsoft YaHei',sans-serif;color:#1f2937;line-height:1.65;font-size:14px;">
  <div style="font-size:20px;font-weight:700;color:#b91c1c;margin-bottom:14px;">主机资源告警</div>

  <div style="margin-bottom:14px;">
    <div>主机IP：{{ host }}</div>
    <div>告警级别：{{ level }}</div>
    <div>告警时间：{{ alertTime }}</div>
    <div>告警ID：{{ alertId }}</div>
  </div>

  <div style="font-weight:700;margin-top:12px;">告警指标</div>
  <pre style="font-family:Consolas,'Microsoft YaHei',monospace;white-space:pre-wrap;margin:6px 0 14px 0;color:#111827;background:transparent;">{{ alertItems }}</pre>

  <div style="font-weight:700;margin-top:12px;">资源概览</div>
  <div style="margin:6px 0 14px 0;">
    <div>CPU：{{ cpuText }}</div>
    <div>内存：{{ memoryText }}</div>
    <div>磁盘：{{ diskText }}</div>
  </div>

  <div style="font-weight:700;margin-top:12px;">告警原因</div>
  <pre style="font-family:Consolas,'Microsoft YaHei',monospace;white-space:pre-wrap;margin:6px 0 14px 0;color:#111827;background:transparent;">{{ alertReason }}</pre>

  <div>请及时检查主机运行状态。</div>
</div>
